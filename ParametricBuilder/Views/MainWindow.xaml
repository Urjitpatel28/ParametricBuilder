<Window x:Class="ParametricBuilder.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ParametricBuilder"
        xmlns:viewmodels="clr-namespace:ParametricBuilder.ViewModels"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        xmlns:helpers="clr-namespace:ParametricBuilder.Helpers"
        xmlns:behaviors="clr-namespace:ParametricBuilder.Behavior"
        d:DataContext="{d:DesignInstance Type=viewmodels:MainWindowViewModel}"
        mc:Ignorable="d"
        Title="{Binding ApplicationVersion}"
        Height="800" Width="1000"
        MinWidth="550" MinHeight="450"
        WindowStartupLocation="CenterScreen"
        Background="#F4F4F4">

    <Window.Resources>
        <helpers:CommaSeparatedValuesConverter x:Key="CommaSeparatedValuesConverter"/>
        <helpers:ParameterToTooltipConverter x:Key="ParameterToTooltipConverter"/>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        
        <!-- TextBox Template -->
        <DataTemplate x:Key="TextBoxParameterTemplate">
            <TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 Padding="3"
                 FontSize="12"
                 BorderBrush="#aaa"
                 Background="White"
                 ToolTip="{Binding ., Converter={StaticResource ParameterToTooltipConverter}}"/>
        </DataTemplate>

        <!-- ComboBox Template -->
        <DataTemplate x:Key="ComboBoxParameterTemplate">
            <ComboBox ItemsSource="{Binding AllowedValues}"
              SelectedItem="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
              Padding="3"
              FontSize="12"
              Background="White"
              BorderBrush="#aaa"/>
        </DataTemplate>

        <!-- Multi-Select Dropdown Template -->
        <DataTemplate x:Key="MultiSelectParameterTemplate">
            <ListBox ItemsSource="{Binding AllowedValues}" 
         SelectionMode="Multiple"
         Background="White"
         BorderBrush="#aaa"
         Padding="3"
         FontSize="12">
                <i:Interaction.Behaviors>
                    <behaviors:ListBoxSelectedItemsBehavior SelectedItems="{Binding SelectedValues, Mode=TwoWay}" />
                </i:Interaction.Behaviors>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox Content="{Binding}" 
                      IsChecked="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected, Mode=TwoWay}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DataTemplate>

        <!-- Template Selector -->
        <helpers:ParameterTemplateSelector x:Key="ParameterSelector"
                                   TextBoxTemplate="{StaticResource TextBoxParameterTemplate}"
                                   ComboBoxTemplate="{StaticResource ComboBoxParameterTemplate}"
                                   MultiSelectTemplate="{StaticResource MultiSelectParameterTemplate}"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Title -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <!-- File Path Input -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
            <RowDefinition Height="*"/>
            <!-- Parameter List -->
            <RowDefinition Height="Auto"/>
            <!-- Buttons -->
            <RowDefinition Height="Auto"/>
            <!-- log -->
            <RowDefinition Height="25"/>
            <!-- status -->

        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="Select Configurator Document :" 
                   FontSize="12" 
                   FontWeight="Bold" 
                   Foreground="#333" 
                   Margin="5"
                   HorizontalAlignment="Left"/>

        <!-- File Path Input & Browse Button -->
        <Grid Grid.Row="1" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox ItemsSource="{Binding Configurators}"
                      SelectedValue="{Binding SelectedConfigurator, Mode=TwoWay}"                      
                      DisplayMemberPath="DisplayName"
                      Padding="5"
                      Margin="0 0 10 0"
                      FontSize="12"
                      BorderThickness="1"
                      BorderBrush="#aaa"
                      Background="White"/>

            <!-- Action Buttons -->
            <Button Command="{Binding GetExcelParametersCommand}" 
                     Content="Get Parameters"
                     Width="120"
                     Padding="5"
                     FontSize="12"
                     FontWeight="Bold"
                     Background="#FF8C00"
                     Foreground="Black"
                     BorderBrush="Black"
                     Cursor="Hand"
                     Margin="5 0"
                     Grid.Column="1"/>

            <!--<Button Command="{Binding BrowseCommand}" 
                    Content="Browse"
                    Width="80"
                    Padding="5"
                    FontSize="12"
                    FontWeight="Bold"
                    Background="#0078D7" 
                    Foreground="White"
                    BorderBrush="#005A9E"
                    Cursor="Hand"
                    Grid.Column="1" Visibility="Collapsed"/>-->
        </Grid>

        <Grid Margin="5" Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Output Path : " VerticalAlignment="Center"/>
            <TextBox Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
        Grid.Column="1" VerticalAlignment="Center" Margin="10 0 0 0" Height="25" VerticalContentAlignment="Center" IsReadOnly="True"/>
            <Button Grid.Column="2" Content="..." Width="25" Margin="5 0 5 0" Height="25" Command="{Binding ChangeOutputPathCommand}"/>
        </Grid>

        <Grid Margin="5" Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Select Model : " VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
               ItemsSource="{Binding Models}"
               SelectedItem="{Binding SelectedModel, Mode=TwoWay}"
               VerticalAlignment="Center"
               Margin="10 0 5 0"/>
        </Grid>

        <Grid Margin="5" Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <!-- Parameter List -->
        <Border 
                Margin="5"
                Padding="10"
                BorderThickness="1"
                BorderBrush="#ddd"
                Background="White"
                CornerRadius="5"
                Effect="{DynamicResource DropShadowEffect}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Parameters}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="5" Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="3*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{Binding Name}" 
                                           FontSize="12"
                                           FontWeight="Bold"
                                           Foreground="#333"
                                           VerticalAlignment="Center"
                                           Grid.Column="0"/>

                                <ContentControl Grid.Column="1"
                                                Content="{Binding}"
                                                Focusable="False"
                                                ContentTemplateSelector="{StaticResource ParameterSelector}"
                                                IsEnabled="{Binding IsEnabled}"
                                                Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibilityConverter}}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
            <Border Grid.Column="1"
                    Margin="5"
                    Padding="10"
                    BorderThickness="1"
                    BorderBrush="#ddd"
                    Background="White"
                    CornerRadius="5">
                <Image Source="{Binding SelectedConfigurator.GeometryImagePathAbsolute,UpdateSourceTrigger=PropertyChanged}"  Stretch="Uniform"/>
            </Border>
        </Grid>
        
        <Grid Grid.Row="5">
            <!-- Action Buttons Group -->
            <StackPanel Orientation="Horizontal" Grid.Column="0" HorizontalAlignment="Left">
                <Button Command="{Binding UpdateCommand}" 
                 Content="Update"
                 Width="60"
                 Margin="5" Padding="5"               
                 FontSize="12"
                 FontWeight="Bold"
                 Background="DeepSkyBlue"
                 Foreground="White"
                 BorderBrush="Black"
                 Cursor="Hand"
                />
                <Button Command="{Binding AddCommand}" 
                 Content="Add"
                 Width="60"
                 Margin="5" Padding="5"
                 FontSize="12"
                 FontWeight="Bold"
                 Background="#28A745"
                 Foreground="White"
                 BorderBrush="Black"
                 Cursor="Hand"
                />
                <Button Command="{Binding DeleteCommand}" 
                 Content="Delete"
                 Width="60"
                 Margin="5" Padding="5"
                 FontSize="12"
                 FontWeight="Bold"
                 Background="Red"
                 Foreground="White"
                 BorderBrush="Black"
                 Cursor="Hand"
                />
            </StackPanel>

            <Button Content="Run CadCaster"
                    Command="{Binding RunCadCasterCommand}"
                    Margin="5" Padding="5"
                    Width="120"
                    VerticalAlignment="Center"       
                    FontSize="12" FontWeight="Bold" Background="#FF6347" BorderBrush="Black" Foreground="White" Cursor="Hand" HorizontalAlignment="Right"/>
        </Grid>





        <ListBox Grid.Row="6" x:Name="LoggerBox" 
                 ItemsSource="{Binding LogMessages}"
                 Margin="5"
                 FontFamily="Segoe UI" 
                 FontSize="12"
                 VerticalAlignment="Stretch"
                 HorizontalAlignment="Stretch"
                 Background="#FFF8F9FA"          
                 Foreground="#212529"           
                 BorderBrush="#DEE2E6"           
                 BorderThickness="1"                 
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.ScrollUnit="Pixel"
                 Visibility="Collapsed">

            <!-- Item template with log level indicators -->
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <TextBlock Text="{Binding}" 
                           TextWrapping="Wrap"
                           FontFamily="Consolas"
                           Padding="5"
                           TextAlignment="Left"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <i:Interaction.Behaviors>
                <helpers:AutoScrollBehavior/>
            </i:Interaction.Behaviors>
        </ListBox>

        <!--Status Bar-->
        <Grid Background="#F4F4F4" HorizontalAlignment="Left" Height="20" Grid.Row="7">
            <StackPanel x:Name="LoadingWheel" Orientation="Horizontal">
                <Viewbox Height="18" Width="18" Stretch="Fill" Margin="5 0 0 0" Visibility="{Binding LoadingWheelVisibility}">
                    <Path Stretch="Fill" Stroke="Black" StrokeThickness="8" Fill="Transparent" Data="M 50,10 A 40,40 0 1 1 90.45,29.55" RenderTransformOrigin="0.5,0.5">
                        <Path.RenderTransform>
                            <RotateTransform/>
                        </Path.RenderTransform>
                        <Path.Style>
                            <Style>
                                <Style.Triggers>
                                    <Trigger Property="Path.IsEnabled" Value="True">
                                        <Trigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="RenderTransform.Angle" From="0" To="360" Duration="0:0:1" RepeatBehavior="Forever" />
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </Trigger.EnterActions>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Path.Style>
                    </Path>
                </Viewbox>
                <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" TextAlignment="Center" Margin="10 0 0 0" Foreground="Black" FontSize="11"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>